# Circle T Arena — Checkfront API Credentials
# Copy this to .env for local development
# Add these same values in Vercel Dashboard > Project > Settings > Environment Variables

# Checkfront subdomain (the part before .checkfront.com or .manage.na1.bookingplatform.app)
CF_SUBDOMAIN=circle-t-arena

# Checkfront domain suffix (the full domain after the subdomain)
CF_DOMAIN=manage.na1.bookingplatform.app

# API Key and Secret from Config sheet B6/B7
# Only needed if Public API is NOT enabled — remove these once Public API is toggled on
CF_API_KEY=your-api-key-here
CF_API_SECRET=your-api-secret-here

# Category IDs for Barn B products (from ct_getProducts call)
CF_BARN_B_CATEGORIES=3742,3752
